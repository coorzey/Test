local function getPlayerMoney()   
    local leaderstats = LP:FindFirstChild("leaderstats")   
    if leaderstats then   
        local m = leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash")   
        if m then return m.Value end   
    end   
    return 0   
end   

local function applyDeepClean()
    pcall(function()
        settings().Rendering.QualityLevel = 1
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        for _, v in pairs(Workspace:GetDescendants()) do
            local name = v.Name:lower()
            if name:find("traffic") or name:find("npc") or name:find("bot") or name:find("car_") or name:find("vehicle") then
                if not v:IsDescendantOf(LP.Character) then v:Destroy() end
            elseif v:IsA("BasePart") and not v:IsDescendantOf(LP.Character) then
                v.Material = Enum.Material.SmoothPlastic
                v.CastShadow = false
                if name:find("tree") or name:find("grass") or name:find("leaf") then v:Destroy() end
            elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") then v:Destroy() end
        end
    end)
end

local function sendWebhook(url, gain, total, races, isOffline)
    pcall(function()
        local data = {["embeds"] = {{
            ["title"] = isOffline and "⚠️ STUCK DETECTED" or "🚀 CORRZEY HUB REPORT",
            ["color"] = isOffline and 16711680 or 65430,
            ["fields"] = {
                {["name"] = "Player", ["value"] = "||" .. tostring(LP.Name) .. "||", ["inline"] = true},
                {["name"] = "Race Profit", ["value"] = "```$" .. tostring(gain) .. "```", ["inline"] = true},
                {["name"] = "Total Profit", ["value"] = "```$" .. tostring(total) .. "```", ["inline"] = true},
                {["name"] = "Races", ["value"] = tostring(races), ["inline"] = true},
            }
        }}}
        if httpRequest then httpRequest({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)}) end
    end)
end

