local function autoSpawnCar()
    pcall(function()
        local spawnRemote = ReplicatedStorage:FindFirstChild("SpawnVehicle", true) or ReplicatedStorage:FindFirstChild("RequestVehicleSpawn", true)
        if spawnRemote then spawnRemote:FireServer("2018 Lily Power TR450") end
        
        task.wait(1)
        local sidebarBtn = nil
        for _, v in pairs(PlayerGui:GetDescendants()) do
            if v.Name == "Spawn" and (v:IsA("ImageButton") or v:IsA("TextButton")) then sidebarBtn = v break end
        end

        if sidebarBtn then
            for _, conn in pairs(getconnections(sidebarBtn.Activated)) do conn:Fire() end
            task.wait(1.5)
            for _, card in pairs(PlayerGui:GetDescendants()) do
                if card:IsA("ImageButton") and card.Visible and (card.Parent.Name == "Vehicles" or card.Parent.Name == "ScrollingFrame") then
                    local match = false
                    for _, label in pairs(card:GetDescendants()) do
                        if label:IsA("TextLabel") and label.Text:lower():find("lily") then match = true break end
                    end
                    if match then
                        local pos = card.AbsolutePosition
                        local size = card.AbsoluteSize
                        VirtualUser:ClickButton1(Vector2.new(pos.X + (size.X/2), pos.Y + (size.Y/2) + 45))
                        for _, conn in pairs(getconnections(card.Activated)) do conn:Fire() end
                        break
                    end
                end
            end
        end
    end)
end

-- CLEANER
local function applyDeepClean()
    pcall(function()
        settings().Rendering.QualityLevel = 1
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(LP.Character) then
                v.Material = Enum.Material.SmoothPlastic
                v.CastShadow = false
            end
        end
    end)
end

local function getPlayerMoney()   
    local leaderstats = LP:FindFirstChild("leaderstats")   
    if leaderstats then   
        local m = leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash")   
        if m then return m.Value end   
    end   
    return 0   
end   

