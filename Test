-- [[ UTILITIES ]]
local function getMoney()
    local ls = LP:FindFirstChild("leaderstats")
    return (ls and (ls:FindFirstChild("Money") or ls:FindFirstChild("Cash"))) and ls.Money.Value or 0
end

local function cleanMemory()
    collectgarbage("collect")
end

-- [[ AUTO CLAIM BYPASS ]]
local function autoClaim()
    pcall(function()
        for _, gui in pairs(PlayerGui:GetChildren()) do
            if gui:IsA("ScreenGui") then
                for _, btn in pairs(gui:GetDescendants()) do
                    if btn:IsA("TextButton") or btn:IsA("ImageButton") then
                        local t = btn:IsA("TextButton") and btn.Text:lower() or ""
                        local n = btn.Name:lower()
                        if t:find("claim") or t:find("collect") or n:find("close") or t == "x" then
                            -- Simulasi klik tanpa menggerakkan mouse asli
                            for _, conn in pairs(getconnections(btn.MouseButton1Click)) do conn:Fire() end
                        end
                    end
                end
            end
        end
    end)
end

