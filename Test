local barFill = Instance.new("Frame")
barFill.Size = UDim2.fromScale(0, 1)
barFill.BorderSizePixel = 0
barFill.Parent = barContainer

--[ RGB LOGIC ]--
task.spawn(function()
    local hue = 0
    RunService.Heartbeat:Connect(function()
        hue = hue + (1/300)
        local rgb = Color3.fromHSV(hue % 1, 0.8, 1)
        titleLabel.TextColor3 = rgb
        barFill.BackgroundColor3 = rgb
    end)
end)

--[ OPTIMIZED RENDERING LOGIC ]--
local function startFastRender()
    local assetsToRender = {}
    local charPos = rootPart.Position
    
    -- Hanya ambil aset yang dekat dengan pemain (Hemat Waktu!)
    for _, asset in ipairs(workspace:GetDescendants()) do
        if asset:IsA("BasePart") then
            if (asset.Position - charPos).Magnitude <= RENDER_RADIUS then
                table.insert(assetsToRender, asset)
            end
        elseif asset:IsA("Texture") or asset:IsA("Decal") then
            table.insert(assetsToRender, asset) -- Texture ringan, ambil saja
        end
    end

    local total = #assetsToRender
    local startTime = tick()

    if total == 0 then
        timeLabel.Text = "NO ASSETS NEARBY"
        task.wait(1)
        screenGui:Destroy()
        return
    end

    for i, asset in ipairs(assetsToRender) do
        ContentProvider:PreloadAsync({asset})
        
        -- Update UI (Setiap 10 aset agar UI tetap smooth)
        if i % 10 == 0 or i == total then
            local progress = i / total
            local elapsed = tick() - startTime
            local remaining = math.ceil((elapsed / progress) - elapsed)
            
            barFill.Size = UDim2.fromScale(progress, 1)
            timeLabel.Text = "ESTIMATED: " .. remaining .. "s"
        end
        
        -- Batching agar tidak lag
        if i % ASSETS_PER_WAIT == 0 then task.wait() end
    end

    timeLabel.Text = "AREA RENDERED!"
    task.wait(0.5)
    
    -- Fade Out Cepat
    TweenService:Create(background, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
    TweenService:Create(titleLabel, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
    TweenService:Create(timeLabel, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
    TweenService:Create(barContainer, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
    local f = TweenService:Create(barFill, TweenInfo.new(0.5), {BackgroundTransparency = 1})
    f:Play()
    f.Completed:Connect(function() screenGui:Destroy() end)
end

task.spawn(startFastRender)
