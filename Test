--[ CONFIGURATION ]--
local SCAN_RADIUS = 60 
local ASSETS_PER_WAIT = 120 -- Jumlah aset per batch agar stabil di mobile

--[ SERVICES ]--
local ContentProvider = game:GetService("ContentProvider")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

--[ UI CLEANUP ]--
if CoreGui:FindFirstChild("CorrZeyRenderer") then
    CoreGui:FindFirstChild("CorrZeyRenderer"):Destroy()
end

--[ UI DESIGN ]--
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "CorrZeyRenderer"
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = 999
screenGui.Parent = CoreGui

local background = Instance.new("Frame")
background.Size = UDim2.fromScale(1, 1)
background.BackgroundColor3 = Color3.fromRGB(5, 5, 5) -- Ultra Dark
background.BorderSizePixel = 0
background.Parent = screenGui

local centerFrame = Instance.new("Frame")
centerFrame.Size = UDim2.fromOffset(500, 200)
centerFrame.Position = UDim2.fromScale(0.5, 0.5)
centerFrame.AnchorPoint = Vector2.new(0.5, 0.5)
centerFrame.BackgroundTransparency = 1
centerFrame.Parent = background

-- JUDUL: CORRZEY HUB (RGB)
local titleLabel = Instance.new("TextLabel")
titleLabel.Text = "CORRZEY HUB"
titleLabel.Size = UDim2.fromScale(1, 0.4)
titleLabel.Font = Enum.Font.GothamBlack
titleLabel.TextSize = 50
titleLabel.BackgroundTransparency = 1
titleLabel.Parent = centerFrame

-- TEKS WAKTU TERSISA (PUTIH)
local timeLabel = Instance.new("TextLabel")
timeLabel.Size = UDim2.fromScale(1, 0.2)
timeLabel.Position = UDim2.fromScale(0.5, 0.5)
timeLabel.AnchorPoint = Vector2.new(0.5, 0.5)
timeLabel.Font = Enum.Font.GothamBold
timeLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- MURNI PUTIH
timeLabel.TextSize = 18
timeLabel.Text = "Estimating time..."
timeLabel.BackgroundTransparency = 1
timeLabel.Parent = centerFrame

-- PROGRESS BAR
local barContainer = Instance.new("Frame")
barContainer.Size = UDim2.new(0.7, 0, 0, 4)
barContainer.Position = UDim2.fromScale(0.5, 0.7)
barContainer.AnchorPoint = Vector2.new(0.5, 0.5)
barContainer.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
barContainer.BorderSizePixel = 0
barContainer.Parent = centerFrame

local barFill = Instance.new("Frame")
barFill.Size = UDim2.fromScale(0, 1)
barFill.BorderSizePixel = 0
barFill.Parent = barContainer

-- STATUS ASSETS
local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.fromScale(1, 0.2)
statusLabel.Position = UDim2.fromScale(0.5, 0.85)
statusLabel.AnchorPoint = Vector2.new(0.5, 0.5)
statusLabel.Font = Enum.Font.GothamMedium
statusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
statusLabel.TextSize = 12
statusLabel.Text = "Scanning..."
statusLabel.BackgroundTransparency = 1
statusLabel.Parent = centerFrame

--[ LOGIC: RGB ANIMATION ]--
task.spawn(function()
    local hue = 0
    RunService.Heartbeat:Connect(function()
        hue = hue + (1/350)
        if hue > 1 then hue = 0 end
        local rgb = Color3.fromHSV(hue, 0.8, 1)
        titleLabel.TextColor3 = rgb
        barFill.BackgroundColor3 = rgb
    end)
end)

--[ LOGIC: RENDERING & TIME CALCULATION ]--
local function startRender()
    -- 1. Scan Lingkungan (Streaming)
    local startPos = rootPart.CFrame
    for i = 1, 10 do
        local angle = math.rad(i * 36)
        rootPart.CFrame = startPos * CFrame.new(Vector3.new(math.cos(angle)*SCAN_RADIUS, 0, math.sin(angle)*SCAN_RADIUS))
        task.wait(0.05)
    end
    rootPart.CFrame = startPos

    -- 2. Render Aset
    local assets = workspace:GetDescendants()
    local total = #assets
    local startTime = tick()
    
    for i, asset in ipairs(assets) do
        if asset:IsA("BasePart") or asset:IsA("MeshPart") or asset:IsA("Texture") then
            ContentProvider:PreloadAsync({asset})
        end
        
        -- Hitung Perkiraan Waktu
        local elapsed = tick() - startTime
        local progress = i / total
        local estimatedTotalTime = elapsed / progress
        local remainingTime = math.max(0, math.ceil(estimatedTotalTime - elapsed))
        
        -- Update UI
        barFill.Size = UDim2.fromScale(progress, 1)
        statusLabel.Text = "ASSETS: " .. i .. " / " .. total
        
        -- Tampilkan Waktu dalam Putih
        if i < 50 then
            timeLabel.Text = "CALCULATING ETR..."
        else
            timeLabel.Text = "ESTIMATED TIME: " .. remainingTime .. " SECONDS"
        end
        
        if i % ASSETS_PER_WAIT == 0 then task.wait() end
    end
    
    -- Selesai
    timeLabel.Text = "RENDER FINISHED"
    statusLabel.Text = "SUCCESSFULLY LOADED " .. total .. " ASSETS"
    task.wait(1.5)
    
    -- Fade Out
    local tween = TweenService:Create(background, TweenInfo.new(1), {BackgroundTransparency = 1})
    TweenService:Create(titleLabel, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
    TweenService:Create(timeLabel, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
    TweenService:Create(barContainer, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()
    TweenService:Create(barFill, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()
    TweenService:Create(statusLabel, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
    
    tween:Play()
    tween.Completed:Connect(function()
        screenGui:Destroy()
    end)
end

task.spawn(startRender)
