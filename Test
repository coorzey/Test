local function sendWebhook(url, gain, total, races, isOffline)
    if not url or url == "" then return end
    pcall(function()
        local data = {
            ["embeds"] = {{
                ["title"] = isOffline and "⚠️ STUCK DETECTED" or "🚀 CORRZEY HUB - REPORT",
                ["color"] = isOffline and 16711680 or 65430,
                ["fields"] = {
                    {["name"] = "👤 Player", ["value"] = "||" .. tostring(LP.Name) .. "||", ["inline"] = true},
                    {["name"] = "💰 Race Profit", ["value"] = "```$" .. tostring(gain) .. "```", ["inline"] = true},
                    {["name"] = "📈 Total Profit", ["value"] = "```$" .. tostring(total) .. "```", ["inline"] = true},
                    {["name"] = "🏁 Total Races", ["value"] = tostring(races) .. " Races", ["inline"] = true},
                },
                ["footer"] = {["text"] = "V58.6 • " .. os.date("%X")},
                ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
            }}
        }
        local payload = HttpService:JSONEncode(data)
        if httpRequest then
            httpRequest({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload})
        else
            HttpService:PostAsync(url, payload)
        end
    end)
end

-- MAIN LOOP
task.spawn(function()
    while true do
        task.wait(0.5)
        if running then
            local hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
            local seat = hum and hum.SeatPart
            if seat and seat:IsA("VehicleSeat") then
                local car = seat.Parent; while car and not car:IsA("Model") do car = car.Parent end
                
                closePrizePopup()
                
                -- FORCE STOP BEFORE TELEPORT
                seat.AssemblyLinearVelocity = Vector3.new(0,0,0)
                seat.AssemblyAngularVelocity = Vector3.new(0,0,0)
                car:PivotTo(CFrame.new(startPos + Vector3.new(0,5,0)) * CFrame.Angles(0, math.rad(startRot), 0))
                
                task.wait(0.05)
                seat.AssemblyLinearVelocity = Vector3.new(0,0,0)
                
                status.Text = "● WAITING RIVAL..."
                local rivalFound = false
                repeat 
                    task.wait(1)
                    if seat then seat.AssemblyLinearVelocity = Vector3.new(0,0,0) end
                    for _, p in pairs(Players:GetPlayers()) do 
                        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            local rHum = p.Character:FindFirstChildOfClass("Humanoid")
                            if (p.Character.HumanoidRootPart.Position - startPos).Magnitude < 25 and (rHum and rHum.SeatPart) then 
                                rivalFound = true 
                            end 
                        end
                    end
                until not running or rivalFound
                
                if running and rivalFound then
                    moneyBeforeRace = getPlayerMoney()
                    for i = 18, 1, -1 do 
                        if not running then break end
                        status.Text = "● START IN: "..i.."s"
                        if seat then seat.AssemblyLinearVelocity = Vector3.new(0,0,0) end
                        task.wait(1) 
                    end
                    
                    if running then
                        for i, d in ipairs(path) do
                            if not running or not seat.Parent then break end
                            status.Text = "● RACING: " .. i .. "/41"
                            local cf = CFrame.new(d.pos[1], d.pos[2]+5, d.pos[3]) * CFrame.Angles(0, math.rad(d.rot), 0)
                            seat.AssemblyLinearVelocity = Vector3.new(0,0,0)
                            car:PivotTo(cf)
                            task.wait(0.05)
                            seat.AssemblyLinearVelocity = cf.LookVector * 165
                            task.wait(math.random(15, 18)/10) 
                        end
                        
                        status.Text = "● FINISHING..."
                        task.wait(3)
                        
                        local currentMoney = getPlayerMoney()
                        local gain = currentMoney - moneyBeforeRace
                        
                        if gain > 0 then 
                            totalMoneyEarned = totalMoneyEarned + gain
                            sessionRaces = sessionRaces + 1
                            moneyLabel.Text = "Profit: $" .. totalMoneyEarned
                            raceLabel.Text = "Races: " .. sessionRaces
                            task.spawn(function() sendWebhook(MAIN_WEBHOOK, gain, totalMoneyEarned, sessionRaces, false) end)
                        end
                        task.wait(2)
                    end
                end
            else status.Text = "● SIT IN CAR!" end
        end
    end
end)

