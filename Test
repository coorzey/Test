-- [[ FUNGSI AUTO SPAWN KHUSUS MIDNIGHT CHASERS - EXACT TARGETING ]]
local function autoSpawnCar()
    pcall(function()
        -- 1. Mencoba Force Remote (Bypass UI)
        local spawnRemote = ReplicatedStorage:FindFirstChild("SpawnVehicle", true) or 
                            ReplicatedStorage:FindFirstChild("RequestVehicleSpawn", true)
        
        if spawnRemote and spawnRemote:IsA("RemoteEvent") then
            spawnRemote:FireServer("2018 Lily Power TR450") 
        end

        -- 2. Mencari Sidebar Button
        local sidebarBtn = nil
        for _, v in pairs(PlayerGui:GetDescendants()) do
            if v.Name == "Spawn" and (v:IsA("ImageButton") or v:IsA("TextButton")) then
                sidebarBtn = v
                break
            end
        end

        if sidebarBtn then
            -- Klik sidebar
            for _, conn in pairs(getconnections(sidebarBtn.Activated)) do conn:Fire() end
            task.wait(1.5) -- Menunggu list mobil benar-benar muncul

            -- 3. PERBAIKAN TOTAL: Scan Nama Mobil secara Mendalam
            for _, card in pairs(PlayerGui:GetDescendants()) do
                -- Pastikan kita hanya mengecek tombol di dalam daftar kendaraan
                if card:IsA("ImageButton") and card.Visible and (card.Parent.Name == "Vehicles" or card.Parent.Name == "ScrollingFrame") then
                    
                    local foundCorrectName = false
                    -- Cari Label Teks di dalam kartu mobil
                    for _, label in pairs(card:GetDescendants()) do
                        if label:IsA("TextLabel") then
                            local txt = label.Text:lower()
                            -- Cek keyword yang sangat spesifik
                            if txt:find("lily") and txt:find("tr450") then
                                foundCorrectName = true
                                break
                            end
                        end
                    end

                    -- Hanya klik jika nama mobil benar-benar ditemukan di dalam kartu tersebut
                    if foundCorrectName then
                        local pos = card.AbsolutePosition
                        local size = card.AbsoluteSize
                        
                        -- Klik fisik menggunakan VirtualUser tepat di tengah kartu
                        VirtualUser:ClickButton1(Vector2.new(pos.X + (size.X/2), pos.Y + (size.Y/2) + 50))
                        
                        -- Jalankan koneksi klik internal
                        local connections = {"MouseButton1Click", "MouseButton1Down", "Activated"}
                        for _, event in ipairs(connections) do
                            for _, conn in pairs(getconnections(card[event])) do 
                                conn:Fire() 
                            end
                        end
                        break -- Berhenti mencari setelah ketemu yang benar
                    end
                end
            end
        end
    end)
end

-- FUNGSI SUPER LOW GRAPHIC + PURGE (TIDAK DIUBAH)
local function applyDeepClean()
    pcall(function()
        settings().Rendering.QualityLevel = 1
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.Brightness = 1
        for _, v in pairs(Workspace:GetDescendants()) do
            local name = v.Name:lower()
            if name:find("traffic") or name:find("npc") or name:find("bot") or name:find("car_") then
                if not v:IsDescendantOf(LP.Character) then v:Destroy() end
            elseif v:IsA("BasePart") and not v:IsDescendantOf(LP.Character) then
                v.Material = Enum.Material.SmoothPlastic
                v.Reflectance = 0
                v.CastShadow = false
                if name:find("tree") or name:find("grass") or name:find("bush") or name:find("leaf") then
                    v:Destroy()
                end
            elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Sky") or v:IsA("Explosion") then
                v:Destroy()
            elseif v:IsA("MeshPart") then
                v.MeshId = ""
            end
        end
    end)
end

