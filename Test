-- Full Rendering & Map Loader Script
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")

local function ForceRender()
    -- 1. Menghilangkan Batas Pandang (Fog/Kabut)
    Lighting.FogEnd = 100000 -- Jarak pandang maksimal
    Lighting.FogStart = 0
    Lighting.GlobalShadows = true -- Opsional: Aktifkan jika ingin visual tetap bagus
    
    -- 2. Memaksa Rendering pada Level Tertinggi
    if settings().Rendering then
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level21 -- Set ke Ultra
    end

    -- 3. Bypass StreamingEnabled (Looping melalui semua part)
    -- Ini memaksa engine untuk memuat properti visual part tersebut
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CastShadow = true -- Memaksa engine menghitung cahaya pada objek ini
            if v:IsA("MeshPart") or v:IsA("SpecialMesh") then
                -- Memaksa pemuatan tekstur mesh
                local temp = v.Parent
            end
        end
    end

    -- 4. Memaksa Focus Camera ke seluruh area (Singkat)
    -- Ini memberitahu server bahwa player "melihat" segalanya
    local player = Players.LocalPlayer
    if player then
        player.ReplicationFocus = game.Workspace
    end
end

-- Menjalankan fungsi
task.spawn(ForceRender)

print("Full Map Rendering Attempted. Harap tunggu beberapa saat agar aset termuat.")
