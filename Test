--[ LOGIC ANIMASI RGB ]--
local function startRGB()
    local hue = 0
    RunService.Heartbeat:Connect(function()
        hue = hue + (1/400) -- Kecepatan ganti warna (semakin kecil semakin lambat)
        if hue > 1 then hue = 0 end
        
        local color = Color3.fromHSV(hue, 1, 1)
        titleLabel.TextColor3 = color
        line.BackgroundColor3 = color
        barFill.BackgroundColor3 = color -- Bar juga ikut RGB agar keren
    end)
end

--[ LOGIC RENDERING (Sama seperti sebelumnya) ]--
local function startScanning()
    local startPos = rootPart.CFrame
    statusLabel.Text = "Synchronizing Environmental Data (Streaming)..."
    
    for i = 1, 12 do -- Sedikit lebih lama untuk scanning
        local angle = math.rad(i * 30)
        local offset = Vector3.new(math.cos(angle) * SCAN_RADIUS, 0, math.sin(angle) * SCAN_RADIUS)
        rootPart.CFrame = startPos * CFrame.new(offset)
        task.wait(0.08)
    end
    
    rootPart.CFrame = startPos
end

local function forceRender()
    startRGB() -- Mulai efek RGB
    
    startScanning()
    
    local assets = workspace:GetDescendants()
    local total = #assets
    
    for i, asset in ipairs(assets) do
        if asset:IsA("BasePart") or asset:IsA("MeshPart") or asset:IsA("Texture") or asset:IsA("Decal") then
            ContentProvider:PreloadAsync({asset})
        end
        
        -- Update UI
        local progress = i / total
        statusLabel.Text = "Forcing Render: " .. math.floor(progress * 100) .. "% (" .. i .. "/" .. total .. ")"
        barFill.Size = UDim2.fromScale(progress, 1)
        
        if i % 120 == 0 then task.wait() end
    end
    
    statusLabel.Text = "Complete! Returning to game..."
    task.wait(1.5)
    
    -- Fade Out Modern
    local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    TweenService:Create(background, tweenInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(titleLabel, tweenInfo, {TextTransparency = 1}):Play()
    TweenService:Create(statusLabel, tweenInfo, {TextTransparency = 1}):Play()
    TweenService:Create(barContainer, tweenInfo, {BackgroundTransparency = 1}):Play()
    local finalBarTween = TweenService:Create(barFill, tweenInfo, {BackgroundTransparency = 1})
    
    finalBarTween:Play()
    finalBarTween.Completed:Connect(function()
        screenGui:Destroy() -- Layar kembali seperti biasa
    end)
end

-- Eksekusi
task.spawn(forceRender)
