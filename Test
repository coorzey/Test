-- FUNGSI RENDERING 1 MAP (POTATO MODE)
local function applyDeepClean()
    pcall(function()
        -- Paksa settingan engine terendah
        settings().Rendering.QualityLevel = 1
        settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.VeryLow
        
        -- Lighting Minimalis
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.Brightness = 1
        Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
        
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(LP.Character) then
                -- TETAP TERENDER: Tapi sangat ringan
                v.Material = Enum.Material.SmoothPlastic
                v.Reflectance = 0
                v.CastShadow = false
                
                -- Hapus dekorasi yang menempel di part (Tekstur jalan, dll)
                for _, child in pairs(v:GetChildren()) do
                    if child:IsA("Decal") or child:IsA("Texture") then
                        child:Destroy()
                    end
                end
                
                -- Hapus objek penghambat FPS
                local name = v.Name:lower()
                if name:find("tree") or name:find("leaf") or name:find("grass") or name:find("bush") or name:find("cloud") then
                    v:Destroy()
                end
            elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Explosion") or v:IsA("Fire") or v:IsA("Sparkles") then
                v:Destroy()
            end
        end
    end)
end

-- FUNGSI CLOSE PRIZE POPUP
local function closePrizePopup()
    pcall(function()
        for _, gui in pairs(PlayerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Enabled and gui.Name ~= "DeltaAutoFarm" then
                for _, btn in pairs(gui:GetDescendants()) do
                    if (btn:IsA("ImageButton") or btn:IsA("TextButton")) and btn.Visible then
                        local n = btn.Name:lower()
                        if n == "x" or n:find("close") or n:find("exit") then
                            pcall(function()
                                for _, conn in pairs(getconnections(btn.MouseButton1Click)) do conn:Fire() end
                            end)
                        end
                    end
                end
            end
        end
    end)
end

local function getPlayerMoney()   
    local leaderstats = LP:FindFirstChild("leaderstats")   
    if leaderstats then   
        local m = leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash")   
        if m then return m.Value end   
    end   
    return 0   
end   

