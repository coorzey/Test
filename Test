local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local FileName = "CorrzeyHub_PS_Config.json"

local function SavePSLink(link)
    local success, err = pcall(function()
        writefile(FileName, HttpService:JSONEncode({PS_Link = link}))
    end)
end

local function LoadPSLink()
    if isfile(FileName) then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile(FileName))
        end)
        if success and data then return data.PS_Link end
    end
    return ""
end

-- Masukkan ke dalam Frame Utama (Ganti 'MainFrame' sesuai variabel di script utamamu)
local ParentFrame = MainFrame 

local PSBox = Instance.new("TextBox")
PSBox.Name = "PS_Input"
PSBox.Parent = ParentFrame
PSBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
PSBox.Position = UDim2.new(0, 10, 0, 380) -- Sesuaikan posisi agar di bawah menu lain
PSBox.Size = UDim2.new(0, 180, 0, 30)
PSBox.Font = Enum.Font.GothamSemibold
PSBox.PlaceholderText = "Paste Link PS..."
PSBox.Text = LoadPSLink()
PSBox.TextColor3 = Color3.fromRGB(255, 255, 255)
PSBox.TextSize = 12

local PSButton = Instance.new("TextButton")
PSButton.Name = "PS_JoinBtn"
PSButton.Parent = ParentFrame
PSButton.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
PSButton.Position = UDim2.new(0, 10, 0, 415)
PSButton.Size = UDim2.new(0, 180, 0, 35)
PSButton.Font = Enum.Font.GothamBold
PSButton.Text = "JOIN PRIVATE SERVER"
PSButton.TextColor3 = Color3.fromRGB(255, 255, 255)
PSButton.TextSize = 13

local UICorner1 = Instance.new("UICorner")
UICorner1.CornerRadius = UDim.new(0, 6)
UICorner1.Parent = PSBox

local UICorner2 = Instance.new("UICorner")
UICorner2.CornerRadius = UDim.new(0, 6)
UICorner2.Parent = PSButton

PSButton.MouseButton1Click:Connect(function()
    local link = PSBox.Text
    if link ~= "" then
        SavePSLink(link)
        local code = link:match("privateServerLinkCode=(%d+)") or link:match("code=(%w+)")
        
        if code then
            PSButton.Text = "TELEPORTING..."
            TeleportService:TeleportToPlaceInstance(game.PlaceId, code, player)
        else
            PSButton.Text = "LINK INVALID!"
            task.wait(2)
            PSButton.Text = "JOIN PRIVATE SERVER"
        end
    else
        PSButton.Text = "KOSONG!"
        task.wait(1)
        PSButton.Text = "JOIN PRIVATE SERVER"
    end
end)
