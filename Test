local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

-- 1. FPS UNLOCKER & PERFORMANCE SETTINGS
-- Mencoba mematikan batasan frame rate jika executor mendukung
if setfpscap then
    setfpscap(999) 
end

settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level01

-- 2. KONFIGURASI PENGHAPUSAN
local TARGET_NAMES = {
    "tree", "leaf", "bush", "grass", "flower", "cloud", "building", 
    "rock", "stone", "decor", "water", "prop", "fence", "bench", 
    "particle", "smoke", "fire", "sparkle", "dust", "atmosphere"
}

-- 3. FUNGSI OPTIMASI AGRESIF (HAPUS TOTAL)
local function ultraOptimize(obj)
    -- Cek nama objek berdasarkan daftar target
    local isTrash = false
    for _, name in pairs(TARGET_NAMES) do
        if obj.Name:lower():find(name) then
            isTrash = true
            break
        end
    end

    if isTrash then
        obj:Destroy()
    elseif obj:IsA("BasePart") or obj:IsA("MeshPart") then
        -- Objek yang tersisa dibuat se-ringan mungkin
        obj.Material = Enum.Material.Plastic
        obj.Reflectance = 0
        obj.CastShadow = false
        if obj:IsA("MeshPart") then
            obj.RenderFidelity = Enum.RenderFidelity.Precise
        end
    elseif obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
        obj:Destroy()
    elseif obj:IsA("PostEffect") or obj:IsA("BloomEffect") or obj:IsA("BlurEffect") or obj:IsA("SunRaysEffect") then
        obj:Destroy()
    end
end

-- 4. FULL BRIGHT (Agar tidak gelap setelah lampu dihapus)
local function activateFullBright()
    Lighting.Brightness = 2
    Lighting.ClockTime = 14
    Lighting.FogEnd = 100000
    Lighting.GlobalShadows = false
    Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
    
    -- Memaksa cahaya tetap terang setiap saat
    Lighting:GetPropertyChangedSignal("ClockTime"):Connect(function()
        Lighting.ClockTime = 14
    end)
end

-- 5. EKSEKUSI MASSAL (Satu Map Full)
print("Memulai pembersihan total...")

for _, v in pairs(Workspace:GetDescendants()) do
    pcall(function() ultraOptimize(v) end)
end

-- Menghapus objek baru yang muncul (StreamingEnabled)
Workspace.DescendantAdded:Connect(function(v)
    pcall(function() ultraOptimize(v) end)
end)

-- Mengoptimalkan Terrain Air jika ada
