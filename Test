-- [[ FUNGSI AUTO SPAWN KHUSUS LILY POWER TR450 ]]
local function autoSpawnCar()
    pcall(function()
        local spawnRemote = ReplicatedStorage:FindFirstChild("SpawnVehicle", true) or 
                            ReplicatedStorage:FindFirstChild("RequestVehicleSpawn", true)
        
        if spawnRemote and spawnRemote:IsA("RemoteEvent") then
            spawnRemote:FireServer("2018 Lily Power TR450") 
        end

        local sidebarBtn = nil
        for _, v in pairs(PlayerGui:GetDescendants()) do
            if v.Name == "Spawn" and (v:IsA("ImageButton") or v:IsA("TextButton")) then
                sidebarBtn = v
                break
            end
        end

        if sidebarBtn then
            for _, conn in pairs(getconnections(sidebarBtn.Activated)) do conn:Fire() end
            task.wait(1.5)

            for _, card in pairs(PlayerGui:GetDescendants()) do
                if card:IsA("ImageButton") and card.Visible and (card.Parent.Name == "Vehicles" or card.Parent.Name == "ScrollingFrame") then
                    local isCorrectCar = false
                    for _, label in pairs(card:GetDescendants()) do
                        if label:IsA("TextLabel") then
                            local txt = label.Text:lower()
                            if txt:find("lily") and txt:find("tr450") then
                                isCorrectCar = true
                                break
                            end
                        end
                    end

                    if isCorrectCar then
                        local pos = card.AbsolutePosition
                        local size = card.AbsoluteSize
                        VirtualUser:ClickButton1(Vector2.new(pos.X + (size.X/2), pos.Y + (size.Y/2) + 45))
                        for _, conn in pairs(getconnections(card.Activated)) do conn:Fire() end
                        break
                    end
                end
            end
        end
    end)
end

