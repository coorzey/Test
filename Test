-- [[ TAB LOGIC ]]
local function switchTab(tabNum)
    currentSheet = tabNum
    if tabNum == 1 then
        container1.Visible = true
        container2.Visible = false
        sheet1Btn.BackgroundColor3 = clr_btn_off; sheet1Btn.TextColor3 = Color3.new(1,1,1)
        sheet2Btn.BackgroundColor3 = Color3.fromRGB(25,25,25); sheet2Btn.TextColor3 = Color3.new(0.6,0.6,0.6)
    else
        container1.Visible = false
        container2.Visible = true
        sheet2Btn.BackgroundColor3 = clr_btn_off; sheet2Btn.TextColor3 = Color3.new(1,1,1)
        sheet1Btn.BackgroundColor3 = Color3.fromRGB(25,25,25); sheet1Btn.TextColor3 = Color3.new(0.6,0.6,0.6)
    end
end

sheet1Btn.MouseButton1Click:Connect(function() switchTab(1) end)
sheet2Btn.MouseButton1Click:Connect(function() switchTab(2) end)

-- [[ MINIMIZE LOGIC ]]
toggleBtn.MouseButton1Click:Connect(function()   
    isMinimized = not isMinimized
    container1.Visible = not isMinimized and (currentSheet == 1)
    container2.Visible = not isMinimized and (currentSheet == 2)
    tabHolder.Visible = not isMinimized
    frame:TweenSize(isMinimized and UDim2.new(0, 260, 0, 35) or UDim2.new(0, 260, 0, 220), "Out", "Quad", 0.3, true)
    toggleBtn.Text = isMinimized and "+" or "−"
end)

-- [[ FEATURE LOGIC ]]
farmBtn.MouseButton1Click:Connect(function()
    running = not running
    farmBtn.Text = running and "STOP FARM" or "START FARMING"
    farmBtn.BackgroundColor3 = running and Color3.fromRGB(180, 0, 0) or Color3.fromRGB(0, 120, 255)
    status.Text = running and "● STATUS: ACTIVE" or "● STATUS: READY"
end)

cpuBtn.MouseButton1Click:Connect(function()
    renderingEnabled = not renderingEnabled
    RunService:Set3dRenderingEnabled(renderingEnabled)
    cpuBtn.Text = renderingEnabled and "NEON DARK: OFF" or "NEON DARK: ON"
end)

