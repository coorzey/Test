-- [[ OMEGA RENDER ENGINE (FULL MAP LOAD) ]]
local function startOmegaWorldRender()
    local BATCH_SIZE = 1000 
    local renderGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    renderGui.Name = "CorrZeyOmegaRender"
    renderGui.IgnoreGuiInset = true
    renderGui.DisplayOrder = 99999

    local bg = Instance.new("Frame", renderGui)
    bg.Size = UDim2.fromScale(1, 1)
    bg.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
    bg.BorderSizePixel = 0

    local label = Instance.new("TextLabel", bg)
    label.Size = UDim2.new(1, 0, 0, 60); label.Position = UDim2.new(0, 0, 0.4, 0); label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBlack; label.TextSize = 26; label.TextColor3 = Color3.new(1,1,1)
    label.Text = "CORRZEY HUB: SCANNING WORLD..."

    local subLabel = Instance.new("TextLabel", bg)
    subLabel.Size = UDim2.new(1, 0, 0, 30); subLabel.Position = UDim2.new(0, 0, 0.4, 60); subLabel.BackgroundTransparency = 1
    subLabel.Font = Enum.Font.GothamBold; subLabel.TextSize = 14; subLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    subLabel.Text = "Wait, collecting every single asset in map..."

    local barContainer = Instance.new("Frame", bg)
    barContainer.Size = UDim2.new(0, 400, 0, 12); barContainer.Position = UDim2.new(0.5, -200, 0.5, 40); barContainer.BackgroundColor3 = Color3.fromRGB(30, 30, 30); Instance.new("UICorner", barContainer)

    local barFill = Instance.new("Frame", barContainer)
    barFill.Size = UDim2.new(0, 0, 1, 0); barFill.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Instance.new("UICorner", barFill)

    task.spawn(function()
        local h = 0
        while renderGui.Parent do
            h = h + (1/400)
            local col = Color3.fromHSV(h % 1, 0.8, 1)
            label.TextColor3 = col
            barFill.BackgroundColor3 = col
            task.wait()
        end
    end)

    task.spawn(function()
        local allAssets = {}
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("Terrain") or v:IsA("Decal") then
                table.insert(allAssets, v)
            end
        end

        local total = #allAssets
        if total > 0 then
            for i = 1, total, BATCH_SIZE do
                local batch = {}
                for j = i, math.min(i + BATCH_SIZE - 1, total) do table.insert(batch, allAssets[j]) end
                ContentProvider:PreloadAsync(batch)
                local ratio = i / total
                local percent = math.floor(ratio * 100)
                label.Text = "OMEGA RENDERING: " .. percent .. "%"
                subLabel.Text = "Loading Assets: " .. i .. " / " .. total
                TweenService:Create(barFill, TweenInfo.new(0.1), {Size = UDim2.fromScale(ratio, 1)}):Play()
                task.wait()
            end
            label.Text = "RENDER COMPLETE! 100%"
            task.wait(1.5)
        end
        local tw = TweenService:Create(bg, TweenInfo.new(1), {BackgroundTransparency = 1})
        for _, v in pairs(bg:GetDescendants()) do
            if v:IsA("Frame") then TweenService:Create(v, TweenInfo.new(1), {BackgroundTransparency = 1}):Play() end
            if v:IsA("TextLabel") then TweenService:Create(v, TweenInfo.new(1), {TextTransparency = 1}):Play() end
        end
        tw:Play(); tw.Completed:Connect(function() renderGui:Destroy() end)
    end)
end

-- [[ CORE UTILITIES ]]
local function applyDeepClean()
    pcall(function()
        settings().Rendering.QualityLevel = 1
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(LP.Character) then
                v.Material = Enum.Material.SmoothPlastic
                v.Reflectance = 0
                v.CastShadow = false
                local name = v.Name:lower()
                if name:find("tree") or name:find("grass") or name:find("bush") then v:Destroy() end
            elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") then
                v:Destroy()
            end
        end
    end)
end

local function closePrizePopup()
    pcall(function()
        for _, gui in pairs(PlayerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Enabled and gui.Name ~= "DeltaAutoFarm" then
                for _, btn in pairs(gui:GetDescendants()) do
                    if (btn:IsA("ImageButton") or btn:IsA("TextButton")) and btn.Visible then
                        local n = btn.Name:lower()
                        if n == "x" or n:find("close") or n:find("exit") then
                            local pos, size = btn.AbsolutePosition, btn.AbsoluteSize
                            VirtualUser:ClickButton1(Vector2.new(pos.X + (size.X/2), pos.Y + (size.Y/2) + 45))
                        end
                    end
                end
            end
        end
    end)
end

local function getPlayerMoney()   
    local leaderstats = LP:FindFirstChild("leaderstats")   
    if leaderstats then   
        local m = leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash")   
        if m then return m.Value end   
    end   
    return 0   
end   

