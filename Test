-- [[ MAIN FARM LOGIC ]]
toggleBtn.MouseButton1Click:Connect(function()
    running = not running
    toggleBtn.Text = running and "STOP" or "START"
    toggleBtn.BackgroundColor3 = running and Color3.fromRGB(150, 0, 0) or Color3.fromRGB(0, 150, 0)
end)

task.spawn(function()
    while true do
        task.wait(0.1)
        if running then
            local char = LP.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local seat = hum and hum.SeatPart
            
            if seat and seat:IsA("VehicleSeat") then
                local car = seat.Parent
                while car and not car:IsA("Model") do car = car.Parent end
                
                -- 1. Reset Position to Start
                statusLbl.Text = "Status: Teleporting to Start"
                seat.AssemblyLinearVelocity = Vector3.new(0,0,0)
                car:PivotTo(CFrame.new(startPos) * CFrame.Angles(0, math.rad(startRot), 0))
                
                -- 2. Wait for Rival/Timer
                task.wait(2) 
                local mBefore = getMoney()
                
                -- 3. Racing Loop
                for i, d in ipairs(path) do
                    if not running or not seat.Parent then break end
                    statusLbl.Text = "Racing: " .. i .. "/" .. #path
                    
                    local targetCF = CFrame.new(d.pos[1], d.pos[2] + 2, d.pos[3]) * CFrame.Angles(0, math.rad(d.rot), 0)
                    
                    -- Stabilize Car before TP
                    seat.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    seat.AssemblyAngularVelocity = Vector3.new(0,0,0)
                    car:PivotTo(targetCF)
                    
                    -- Kecepatan Simulasi (Bypass deteksi instan)
                    task.wait(0.2) 
                end
                
                -- 4. Finishing
                statusLbl.Text = "Status: Claiming..."
                task.wait(1)
                autoClaim()
                
                local mAfter = getMoney()
                if mAfter > mBefore then
                    totalMoneyEarned = totalMoneyEarned + (mAfter - mBefore)
                    sessionRaces = sessionRaces + 1
                    print("Earned: " .. (mAfter - mBefore) .. " | Total: " .. totalMoneyEarned)
                end
                
                cleanMemory()
            else
                statusLbl.Text = "Status: Please Sit in Car"
            end
        else
            statusLbl.Text = "Status: Idle"
        end
    end
end)
